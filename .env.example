# ─── Supabase (obrigatório) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── URL do site (OBRIGATÓRIO — usado no emailRedirectTo do Supabase Auth) ────
# DEVE coincidir com o "Site URL" configurado em:
#   Supabase Dashboard → Authentication → URL Configuration → Site URL
# Em desenvolvimento: http://localhost:3000
# Em produção: https://www.paraguai.com (ou seu domínio)
#
# ATENÇÃO: o Supabase envia e-mails de confirmação para esta URL + /auth/callback
# Adicionar também em "Additional redirect URLs":
#   http://localhost:3000/auth/callback
#   http://localhost:3001/auth/callback  (dev server alternativo)
#   https://www.paraguai.com/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Analytics (opcional — deixar vazio em desenvolvimento) ──────────────────
# Google Analytics 4: criar propriedade em analytics.google.com
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity: criar projeto em clarity.microsoft.com
# Formato: xxxxxxxxxx (10 caracteres)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ─── Webmaster Tools (opcional — preencher após registro) ────────────────────
# Google Search Console: https://search.google.com/search-console
# Valor da meta tag: <meta name="google-site-verification" content="VALOR">
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools: https://www.bing.com/webmasters
# Valor da meta tag: <meta name="msvalidate.01" content="VALOR">
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ─── Chave de serviço Supabase (apenas para tooling local, NUNCA no cliente) ─
# Necessária para: db:seed:execute, storage:init, update_images
# NUNCA use como NEXT_PUBLIC_* — nunca deve ir para o browser
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cron Secret (obrigatório em produção para o scheduler de conectores) ────
# Autentica requisições do Vercel Cron a app/api/cron/connectors/sync — sem
# cookies de sessão disponíveis, este é o único guard dessa rota (Release 1.7
# Wave 2). Configurar em Vercel → Project → Settings → Environment Variables
# (Production + Preview). A rota falha fechada (401) se esta variável não
# estiver definida.
CRON_SECRET=

# ─── Exchange Rate API (obrigatório para o Exchange Engine, Release 1.8 —
# Program A — Wave 1) ──────────────────────────────────────────────────────
# ADR-043: ExchangeRate-API.com, plano Business ($30/mês, 125.000 req/mês,
# atualização a cada 5 min). Gerar em https://www.exchangerate-api.com/.
# Lida diretamente via process.env em
# src/domains/exchange/providers/ExchangeRateApiProvider.ts — não passa por
# lib/env.ts (mesmo precedente de CRON_SECRET: um secret usado só por uma
# operação específica e lazy não deveria derrubar todo import do módulo de
# env compartilhado em ambientes que ainda não o configuraram). Sem esta
# variável, /api/cron/exchange/refresh falha ao tentar buscar cotação —
# nunca ao subir a aplicação.
#
# Program ΔR — Mission ΔR-1.1: sem esta variável E sem OPEN_EXCHANGE_RATES_APP_ID
# abaixo, TODOS os provedores registrados falham e o sistema roda 100% do
# tempo em modo de degradação (usingFallback=true, servindo a última cotação
# real conhecida — nunca um valor fabricado). O cron em si (a cada 5 min)
# só é executado se estiver registrado em vercel.json — confirme que
# "/api/cron/exchange/refresh" está no array "crons" antes de assumir que
# esta chave, sozinha, é suficiente para o câmbio funcionar em produção.
EXCHANGE_RATE_API_KEY=

# Segundo provedor (failover real) — Program ΔR — Mission ΔR-1.1 (Objetivo 7).
# Plano gratuito "Developer" da Open Exchange Rates (openexchangerates.org),
# 1.000 req/mês — suficiente como provedor de reserva (só é chamado quando
# ExchangeRate-API.com falha). Lida em
# src/domains/exchange/providers/OpenExchangeRatesProvider.ts, mesmo
# precedente de não passar por lib/env.ts.
OPEN_EXCHANGE_RATES_APP_ID=
