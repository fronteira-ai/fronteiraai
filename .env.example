# ─── Supabase (obrigatório) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── URL do site (OBRIGATÓRIO — usado no emailRedirectTo do Supabase Auth) ────
# DEVE coincidir com o "Site URL" configurado em:
#   Supabase Dashboard → Authentication → URL Configuration → Site URL
# Em desenvolvimento: http://localhost:3000
# Em produção: https://www.paraguai.com (ou seu domínio)
#
# ATENÇÃO: o Supabase envia e-mails de confirmação para esta URL + /auth/callback
# Adicionar também em "Additional redirect URLs":
#   http://localhost:3000/auth/callback
#   http://localhost:3001/auth/callback  (dev server alternativo)
#   https://www.paraguai.com/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Analytics (opcional — deixar vazio em desenvolvimento) ──────────────────
# Google Analytics 4: criar propriedade em analytics.google.com
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity: criar projeto em clarity.microsoft.com
# Formato: xxxxxxxxxx (10 caracteres)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ─── Webmaster Tools (opcional — preencher após registro) ────────────────────
# Google Search Console: https://search.google.com/search-console
# Valor da meta tag: <meta name="google-site-verification" content="VALOR">
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools: https://www.bing.com/webmasters
# Valor da meta tag: <meta name="msvalidate.01" content="VALOR">
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ─── Chave de serviço Supabase (apenas para tooling local, NUNCA no cliente) ─
# Necessária para: db:seed:execute, storage:init, update_images
# NUNCA use como NEXT_PUBLIC_* — nunca deve ir para o browser
SUPABASE_SERVICE_ROLE_KEY=
